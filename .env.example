# VibeCI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.

# Required for LIVE mode only — Demo mode (the default) runs with no key.
# Live mode needs a quota-enabled key (the Gemini free tier may be 0 for
# gemini-2.0-flash; enable billing or use a quota-enabled key).
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
